# .env.example — Copy to .env and fill in your values

# Required
ELEPHANTQ_DATABASE_URL=postgresql://elephantq:password@localhost/elephantq
ELEPHANTQ_JOBS_MODULES=myapp.jobs

# Worker
ELEPHANTQ_CONCURRENCY=4
ELEPHANTQ_QUEUES=default

# Recommended for production
ELEPHANTQ_LOG_LEVEL=INFO
ELEPHANTQ_TIMEOUTS_ENABLED=true
ELEPHANTQ_DEAD_LETTER_QUEUE_ENABLED=true
ELEPHANTQ_RESULT_TTL=300

# Optional features
# ELEPHANTQ_DASHBOARD_ENABLED=true
# ELEPHANTQ_SCHEDULING_ENABLED=true
# ELEPHANTQ_METRICS_ENABLED=true
# ELEPHANTQ_WEBHOOKS_ENABLED=true
